<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Top Bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="20dp">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_arrow_back"
                android:tint="@color/accent_green"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="رجوع"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="التسجيل المحلي"
                android:textSize="20sp"
                android:textColor="@color/text_primary"
                android:textStyle="bold"
                android:gravity="center"/>

            <ImageView
                android:id="@+id/ivMoonIndicator"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_moon"
                android:tint="@color/accent_green"
                android:alpha="0.5"/>
        </LinearLayout>

        <!-- Timer Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/bg_card"
            app:cardCornerRadius="20dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp"
                android:gravity="center">

                <!-- Recording dot -->
                <View
                    android:id="@+id/recordingIndicator"
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:background="@drawable/recording_dot"
                    android:visibility="gone"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:id="@+id/tvTimer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="00:00:00"
                    android:textSize="52sp"
                    android:textColor="@color/accent_green"
                    android:fontFamily="monospace"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/tvStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="جاهز للتسجيل"
                    android:textSize="14sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginTop="8dp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Quality Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/bg_card"
            app:cardCornerRadius="16dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="جودة الفيديو"
                    android:textSize="15sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginBottom="12dp"/>

                <RadioGroup
                    android:id="@+id/rgQuality"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <RadioButton
                        android:id="@+id/rb720p"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:text="720p HD"
                        android:textColor="@color/text_primary"
                        android:buttonTint="@color/accent_green"
                        android:checked="true"/>

                    <RadioButton
                        android:id="@+id/rb1080p"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:text="1080p FHD"
                        android:textColor="@color/text_primary"
                        android:buttonTint="@color/accent_green"/>
                </RadioGroup>

                <TextView
                    android:id="@+id/tvSelectedQuality"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="720p HD"
                    android:textSize="12sp"
                    android:textColor="@color/accent_green"
                    android:layout_marginTop="8dp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Night Vision Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/bg_card"
            app:cardCornerRadius="16dp"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="الرؤية الليلية"
                        android:textSize="15sp"
                        android:textColor="@color/text_primary"/>

                    <Switch
                        android:id="@+id/switchNightVision"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true"
                        android:thumbTint="@color/accent_green"
                        android:trackTint="#1B4D1B"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/tvNightStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🌙 وضع الليل مفعّل"
                    android:textSize="12sp"
                    android:textColor="@color/accent_green"
                    android:layout_marginTop="8dp"/>

                <Button
                    android:id="@+id/btnNightSettings"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="إعدادات متقدمة"
                    android:textSize="12sp"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:textColor="@color/accent_green"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    app:strokeColor="@color/accent_green_dim"
                    android:layout_marginTop="12dp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Start/Stop Button -->
        <Button
            android:id="@+id/btnStartStop"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:text="▶ بدء التسجيل"
            android:textSize="18sp"
            android:textColor="#000000"
            android:textStyle="bold"
            android:backgroundTint="@color/accent_green"
            style="@style/Widget.MaterialComponents.Button"
            app:cornerRadius="16dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="يعمل في الخلفية عند قفل الشاشة · بدون صوت · MP4"
            android:textSize="11sp"
            android:textColor="@color/text_secondary"
            android:gravity="center"
            android:layout_marginTop="12dp"/>

    </LinearLayout>
</ScrollView>
