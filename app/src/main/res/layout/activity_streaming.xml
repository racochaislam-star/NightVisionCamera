<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="@color/bg_primary" android:fillViewport="true">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:padding="20dp">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="16dp">
            <ImageButton android:id="@+id/btnBack" android:layout_width="40dp" android:layout_height="40dp"
                android:src="@drawable/ic_arrow_back" android:tint="@color/accent_blue"
                android:background="?attr/selectableItemBackgroundBorderless"/>
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="البث المباشر 📡"
                android:textSize="18sp" android:textColor="@color/text_primary"
                android:textStyle="bold" android:gravity="center"/>
            <TextView android:id="@+id/tvFps" android:layout_width="50dp"
                android:layout_height="wrap_content" android:text="0 fps"
                android:textSize="11sp" android:textColor="@color/accent_blue"
                android:fontFamily="monospace" android:gravity="end"/>
        </LinearLayout>
        <androidx.cardview.widget.CardView android:layout_width="match_parent"
            android:layout_height="wrap_content" app:cardBackgroundColor="@color/bg_card"
            app:cardCornerRadius="16dp" android:layout_marginBottom="12dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="20dp" android:gravity="center">
                <TextView android:id="@+id/tvTimer" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:text="00:00:00"
                    android:textSize="44sp" android:textColor="@color/accent_blue"
                    android:fontFamily="monospace" android:textStyle="bold"/>
                <TextView android:id="@+id/tvStatus" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:text="جاهز"
                    android:textSize="13sp" android:textColor="@color/text_secondary"
                    android:layout_marginTop="8dp" android:gravity="center"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>
        <androidx.cardview.widget.CardView android:layout_width="match_parent"
            android:layout_height="wrap_content" app:cardBackgroundColor="#0D1F2D"
            app:cardCornerRadius="14dp" android:layout_marginBottom="12dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="16dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="معلومات الاتصال" android:textSize="12sp" android:textColor="@color/text_secondary"
                    android:layout_marginBottom="6dp"/>
                <TextView android:id="@+id/tvIp" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:text="IP: --"
                    android:textSize="13sp" android:textColor="@color/text_primary" android:fontFamily="monospace"/>
                <TextView android:id="@+id/tvUrl" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:text="http://..."
                    android:textSize="13sp" android:textColor="@color/accent_blue"
                    android:fontFamily="monospace" android:layout_marginTop="4dp"/>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginTop="8dp">
                    <TextView android:id="@+id/tvPin" android:layout_width="0dp"
                        android:layout_height="wrap_content" android:layout_weight="1"
                        android:text="PIN: ----" android:textSize="16sp"
                        android:textColor="@color/accent_green" android:fontFamily="monospace"
                        android:textStyle="bold"/>
                    <Button android:id="@+id/btnResetPin" android:layout_width="wrap_content"
                        android:layout_height="36dp" android:text="تغيير PIN"
                        android:textSize="12sp" android:textColor="@color/accent_green"
                        android:isEnabled="false"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        app:strokeColor="@color/accent_green"/>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>
        <androidx.cardview.widget.CardView android:layout_width="match_parent"
            android:layout_height="wrap_content" app:cardBackgroundColor="@color/bg_card"
            app:cardCornerRadius="14dp" android:layout_marginBottom="12dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="14dp">
                <RadioGroup android:id="@+id/rgQuality" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:orientation="horizontal">
                    <RadioButton android:id="@+id/rb720p" android:layout_width="0dp"
                        android:layout_height="wrap_content" android:layout_weight="1"
                        android:text="720p" android:textColor="@color/text_primary"
                        android:buttonTint="@color/accent_blue" android:checked="true"/>
                    <RadioButton android:id="@+id/rb1080p" android:layout_width="0dp"
                        android:layout_height="wrap_content" android:layout_weight="1"
                        android:text="1080p" android:textColor="@color/text_primary"
                        android:buttonTint="@color/accent_blue"/>
                </RadioGroup>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginTop="8dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="🌙 الرؤية الليلية"
                        android:textSize="13sp" android:textColor="@color/text_primary"/>
                    <Switch android:id="@+id/swNight" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:checked="true"
                        android:thumbTint="@color/accent_green" android:trackTint="#1B4D1B"/>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>
        <Button android:id="@+id/btnStartStop" android:layout_width="match_parent"
            android:layout_height="60dp" android:text="▶ بدء البث"
            android:textSize="17sp" android:textColor="#000000" android:textStyle="bold"
            android:backgroundTint="@color/accent_blue"
            style="@style/Widget.MaterialComponents.Button" app:cornerRadius="14dp"
            android:layout_marginBottom="8dp"/>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal">
            <Button android:id="@+id/btnCopyUrl" android:layout_width="0dp"
                android:layout_height="44dp" android:layout_weight="1" android:text="نسخ الرابط"
                android:textSize="12sp" android:textColor="@color/accent_blue"
                android:isEnabled="false"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                app:strokeColor="@color/accent_blue" android:layout_marginEnd="6dp"/>
            <Button android:id="@+id/btnOpenViewer" android:layout_width="0dp"
                android:layout_height="44dp" android:layout_weight="1" android:text="فتح المشاهد"
                android:textSize="12sp" android:textColor="#000" android:backgroundTint="@color/accent_blue"
                android:isEnabled="false"
                style="@style/Widget.MaterialComponents.Button"/>
        </LinearLayout>
    </LinearLayout>
</ScrollView>