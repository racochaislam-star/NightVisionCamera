<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- Stream View (full screen) -->
    <ImageView
        android:id="@+id/ivStream"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:scaleType="fitCenter"
        android:background="#000"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Top overlay bar -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#AA000000"
        android:padding="12dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_arrow_back"
            android:tint="#FFFFFF"
            android:background="?attr/selectableItemBackgroundBorderless"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="🌙 مشاهدة البث"
            android:textSize="16sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginStart="8dp"/>

        <TextView
            android:id="@+id/tvFps"
            android:layout_width="56dp"
            android:layout_height="wrap_content"
            android:text="0 fps"
            android:textSize="12sp"
            android:textColor="@color/accent_green"
            android:fontFamily="monospace"
            android:gravity="end"/>
    </LinearLayout>

    <!-- Bottom overlay bar -->
    <LinearLayout
        android:id="@+id/bottomBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#CC000000"
        android:padding="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Connection row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <EditText
                android:id="@+id/etServerIp"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="2"
                android:hint="IP الكاميرا"
                android:textColor="#FFFFFF"
                android:textColorHint="#888"
                android:background="@drawable/input_bg"
                android:padding="10dp"
                android:inputType="textUri"
                android:imeOptions="actionDone"
                android:fontFamily="monospace"
                android:textSize="14sp"
                android:layout_marginEnd="8dp"/>

            <EditText
                android:id="@+id/etPort"
                android:layout_width="80dp"
                android:layout_height="44dp"
                android:hint="8080"
                android:text="8080"
                android:textColor="#FFFFFF"
                android:textColorHint="#888"
                android:background="@drawable/input_bg"
                android:padding="10dp"
                android:inputType="number"
                android:fontFamily="monospace"
                android:textSize="14sp"
                android:layout_marginEnd="8dp"/>

            <Button
                android:id="@+id/btnConnect"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:text="اتصال"
                android:textSize="13sp"
                android:textColor="#000"
                android:backgroundTint="@color/accent_green"
                style="@style/Widget.MaterialComponents.Button"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"/>
        </LinearLayout>

        <!-- Status and controls row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:indeterminateTint="@color/accent_green"
                android:visibility="gone"
                android:layout_marginEnd="8dp"/>

            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="أدخل IP الكاميرا واضغط اتصال"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"/>

            <Button
                android:id="@+id/btnSnapshot"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="📷"
                android:textSize="16sp"
                android:backgroundTint="@color/bg_surface"
                style="@style/Widget.MaterialComponents.Button"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:layout_marginStart="6dp"/>

            <Button
                android:id="@+id/btnFullscreen"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="⛶"
                android:textSize="16sp"
                android:backgroundTint="@color/bg_surface"
                style="@style/Widget.MaterialComponents.Button"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:layout_marginStart="6dp"/>

            <Button
                android:id="@+id/btnDisconnect"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="قطع"
                android:textSize="12sp"
                android:textColor="@color/warning_red"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                app:strokeColor="@color/warning_red"
                android:layout_marginStart="6dp"
                android:isEnabled="false"/>
        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
