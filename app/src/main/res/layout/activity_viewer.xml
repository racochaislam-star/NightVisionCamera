<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="#000000">
    <ImageView android:id="@+id/ivStream" android:layout_width="0dp" android:layout_height="0dp"
        android:scaleType="fitCenter" android:background="#000"
        app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent"/>
    <LinearLayout android:id="@+id/topBar" android:layout_width="0dp" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:background="#AA000000" android:padding="12dp"
        app:layout_constraintTop_toTopOf="parent" app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">
        <ImageButton android:id="@+id/btnBack" android:layout_width="36dp" android:layout_height="36dp"
            android:src="@drawable/ic_arrow_back" android:tint="#FFFFFF"
            android:background="?attr/selectableItemBackgroundBorderless"/>
        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="🌙 مشاهدة البث"
            android:textSize="15sp" android:textColor="#FFFFFF" android:textStyle="bold"
            android:gravity="center" android:layout_marginStart="8dp"/>
        <TextView android:id="@+id/tvFps" android:layout_width="56dp" android:layout_height="wrap_content"
            android:text="0 fps" android:textSize="11sp" android:textColor="@color/accent_green"
            android:fontFamily="monospace" android:gravity="end"/>
    </LinearLayout>
    <LinearLayout android:id="@+id/bottomBar" android:layout_width="0dp" android:layout_height="wrap_content"
        android:orientation="vertical" android:background="#CC000000" android:padding="14dp"
        app:layout_constraintBottom_toBottomOf="parent" app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="8dp">
            <EditText android:id="@+id/etIp" android:layout_width="0dp" android:layout_height="44dp"
                android:layout_weight="2" android:hint="IP الكاميرا" android:textColor="#FFFFFF"
                android:textColorHint="#666" android:padding="10dp" android:inputType="textUri"
                android:fontFamily="monospace" android:textSize="14sp"
                android:background="@android:color/transparent"
                android:layout_marginEnd="6dp"/>
            <EditText android:id="@+id/etPin" android:layout_width="70dp" android:layout_height="44dp"
                android:hint="PIN" android:text="" android:textColor="#FFFFFF"
                android:textColorHint="#666" android:padding="10dp" android:inputType="number"
                android:fontFamily="monospace" android:textSize="14sp"
                android:background="@android:color/transparent"
                android:layout_marginEnd="6dp"/>
            <Button android:id="@+id/btnConnect" android:layout_width="wrap_content"
                android:layout_height="44dp" android:text="اتصال" android:textSize="13sp"
                android:textColor="#000" android:backgroundTint="@color/accent_green"
                style="@style/Widget.MaterialComponents.Button" android:paddingStart="14dp" android:paddingEnd="14dp"/>
        </LinearLayout>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical">
            <ProgressBar android:id="@+id/progress" android:layout_width="24dp" android:layout_height="24dp"
                android:indeterminateTint="@color/accent_green" android:visibility="gone" android:layout_marginEnd="8dp"/>
            <TextView android:id="@+id/tvStatus" android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="أدخل IP والـ PIN" android:textSize="12sp"
                android:textColor="@color/text_secondary"/>
            <Button android:id="@+id/btnDisconnect" android:layout_width="wrap_content"
                android:layout_height="36dp" android:text="قطع" android:textSize="12sp"
                android:textColor="@color/warning_red" android:isEnabled="false"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                app:strokeColor="@color/warning_red" android:layout_marginStart="8dp"/>
        </LinearLayout>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>